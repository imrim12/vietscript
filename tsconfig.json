{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node"],
    "noEmit": true,
    "allowJs": true
  },
  "include": [
    "vitest.config.ts",
    "eslint.config.js",
    "scripts/**/*"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist",
    ".nx",
    "coverage",
    "docs/.vitepress/cache",
    "docs/.vitepress/dist",
    "packages",
    "playground",
    "sandbox"
  ]
}

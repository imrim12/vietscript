{
  "version": "0.0.1",
  "type": "module",
  "description": "Vietnamese programming language - Ngôn ngữ lập trình tiếng Việt.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "nx": "nx",
    "lint": "eslint . --fix",
    "build": "nx run-many --target=build --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "coverage:summary": "node scripts/compat-summary.mjs",
    "dev": "vitest --ui",
    "dev:docs": "vitepress dev docs",
    "serve:docs": "vitepress serve docs",
    "build:docs": "vitepress build docs",
    "prepare-husky": "husky",
    "release": "release-it",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imrim12/vietscript.git"
  },
  "keywords": [
    "language",
    "vietscript",
    "vietnamese",
    "programming language"
  ],
  "author": "imrim12",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/imrim12/vietscript/issues"
  },
  "homepage": "https://github.com/imrim12/vietscript#readme",
  "workspaces": [
    "packages/**",
    "sandbox"
  ],
  "dependencies": {
    "@vietscript/cli": "workspace:*",
    "@vietscript/parser": "workspace:*",
    "@vietscript/stdlib": "workspace:*"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@babel/generator": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint/js": "catalog:",
    "@release-it/conventional-changelog": "catalog:",
    "@types/babel__generator": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "@vue/test-utils": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-pnpm": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "jsdom": "catalog:",
    "jsonc-eslint-parser": "catalog:",
    "nx": "catalog:",
    "release-it": "catalog:",
    "rimraf": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitepress": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:",
    "yaml-eslint-parser": "catalog:"
  }
}

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "vite.config.ts",
    "src/**/__test__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}

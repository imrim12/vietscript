{
  "name": "@vietscript/plugin-webpack",
  "version": "1.0.0-beta.1",
  "description": "A VietScript plugin to include .vjs file into Webpack build",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imrim12/vietscript.git",
    "directory": "packages/plugins/webpack"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rimraf ./dist && vite build"
  },
  "devDependencies": {
    "@vitest/ui": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:",
    "webpack": "catalog:",
    "webpack-cli": "catalog:"
  },
  "dependencies": {
    "@babel/generator": "catalog:",
    "@vietscript/parser": "workspace:*"
  }
}

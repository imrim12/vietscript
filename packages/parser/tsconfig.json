{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "strictPropertyInitialization": false,
    "types": ["node", "vite/client", "vitest/globals"],
    "paths": {
      "@parser": ["./src/index.ts"],
      "@parser/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}

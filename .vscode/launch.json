{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run VietScript Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/packages/extension/dist/**/*.js"],
      "preLaunchTask": "Build VietScript Extension"
    },
    {
      "name": "Attach to VietScript Language Server",
      "type": "node",
      "request": "attach",
      "port": 6009,
      "restart": true,
      "outFiles": ["${workspaceFolder}/packages/extension/dist/**/*.js"]
    }
  ],
  "compounds": [
    {
      "name": "Extension + Server",
      "configurations": [
        "Run VietScript Extension",
        "Attach to VietScript Language Server"
      ]
    }
  ]
}
